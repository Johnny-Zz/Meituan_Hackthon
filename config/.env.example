# Do NOT commit real API keys. Copy this file to config/.env.local on your own machine.

# DeepSeek is the only LLM provider for attribution / autonomous iteration.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=DeepSeek-V4-pro

# Qwen is OCR-only for score screenshots.
QWEN_API_KEY=
QWEN_BASE_URL=https://ws-bmzspe69czs7znm9.ap-southeast-1.maas.aliyuncs.com/compatible-mode/v1
QWEN_OCR_MODEL=qwen-vl-ocr

RSD_STUDIO_PORT=8765
RSD_NO_REGRESSION_EPS=1e-6
RSD_SOLVER_SIZE_LIMIT_BYTES=100000
